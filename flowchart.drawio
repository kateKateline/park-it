                <!-- PETUGAS DETAILED MODULES -->
                <mxCell id="petugas_in_mod" value="TRANSAKSI MASUK&#xa;- Select Area (Real-time check)&#xa;- Capture Plate (YOLO AI)&#xa;- Manual Plate Entry&#xa;- Validate Vehicle Status&#xa;- Store Entry Time&#xa;- Generate Unique Barcode&#xa;- Print Karcis" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
