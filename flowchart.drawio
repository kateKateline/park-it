                <mxCell id="owner_dash" value="Owner Dashboard&#xa;(Revenue &amp; Analytics)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontColor=#000000;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="1170" y="680" width="180" height="60" as="geometry"/>
                </mxCell>

                <!-- ADMIN DETAILED MODULES -->
                <mxCell id="admin_users_mod" value="USER MANAGEMENT&#xa;- Form: Name, Username, Role&#xa;- Validation: Unique Username&#xa;- Password Hashing&#xa;- Activity Tracking" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
                    <mxGeometry x="50" y="800" width="160" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="admin_tarif_mod" value="TARIF MANAGEMENT&#xa;- Define Vehicle Types&#xa;- Set Hourly Rates&#xa;- Dynamic Calculation Base" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
