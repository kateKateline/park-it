                <mxCell id="admin_area_mod" value="AREA MANAGEMENT&#xa;- Set Capacity&#xa;- Toggle Status (Suspend)&#xa;- Occupancy Tracking" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
                    <mxGeometry x="390" y="800" width="160" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="admin_kendaraan_mod" value="KENDARAAN &amp; CAMERA&#xa;- Search Plate Database&#xa;- Bulk Delete Log&#xa;- Manage Stream URLs&#xa;- IP Camera Integration" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
                    <mxGeometry x="220" y="910" width="160" height="90" as="geometry"/>
