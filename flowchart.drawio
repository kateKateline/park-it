                <mxCell id="petugas_out_mod" value="TRANSAKSI KELUAR&#xa;- Scan Barcode / Input Plate&#xa;- Fetch Entry Details&#xa;- Auto Calculate Duration&#xa;- Apply Hourly Rate&#xa;- Process Payment&#xa;- Mark as 'Selesai'&#xa;- Print Struk" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;fontSize=10" vertex="1" parent="1">
                    <mxGeometry x="810" y="800" width="180" height="120" as="geometry"/>
