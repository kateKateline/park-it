                </mxCell>

                <!-- DASHBOARDS -->
                <mxCell id="admin_dash" value="Admin Dashboard&#xa;(System KPI &amp; Activity Log)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontColor=#000000;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="250" y="680" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="petugas_dash" value="Petugas Dashboard&#xa;(Live Occupancy &amp; Quick Stats)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontColor=#000000;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="710" y="680" width="180" height="60" as="geometry"/>
