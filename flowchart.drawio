                </mxCell>

                <!-- AUTH DECISION -->
                <mxCell id="auth_check" value="Authenticated?&#xa;&amp; Not Suspended" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000" vertex="1" parent="1">
                    <mxGeometry x="730" y="360" width="140" height="140" as="geometry"/>
                </mxCell>

                <!-- ROLE REDIRECT -->
